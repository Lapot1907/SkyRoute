<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>SkyRoute</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:#0b0d10;
font-family:Arial,sans-serif;
color:white;
}

.app{
max-width:430px;
margin:auto;
min-height:100vh;
padding:15px;
background:linear-gradient(#20282c,#0b0d10);
}

.title{
text-align:center;
font-size:32px;
font-weight:bold;
color:#ffd700;
margin-bottom:15px;
}

.card{
background:#111;
border:1px solid #333;
border-radius:15px;
padding:12px;
margin-bottom:12px;
box-shadow:0 0 10px rgba(0,0,0,.4);
}

.flight{
text-align:center;
font-size:22px;
}

.map{
height:320px;
border-radius:20px;
position:relative;
overflow:hidden;
background:
radial-gradient(circle at 50% 50%,#1f4960,#08131a);
border:2px solid #333;
}

.city{
position:absolute;
font-size:14px;
font-weight:bold;
}

.london{
left:25px;
bottom:60px;
}

.istanbul{
right:25px;
top:70px;
}

.route{
position:absolute;
height:4px;
width:280px;
background:#32ff5f;
left:55px;
top:170px;
transform:rotate(-22deg);
box-shadow:
0 0 8px #32ff5f,
0 0 15px #32ff5f;
}

.plane{
position:absolute;
font-size:34px;
left:140px;
top:145px;
animation:fly 10s linear infinite;
}

@keyframes fly{
0%{
left:55px;
top:220px;
}
100%{
left:285px;
top:120px;
}
}

.gauge{
height:180px;
width:180px;
margin:20px auto;
border-radius:50%;
border:6px solid #444;
background:
radial-gradient(circle,#111 45%,#222 47%,#000 70%);
position:relative;
}

.needle{
position:absolute;
width:4px;
height:70px;
background:white;
left:50%;
top:25px;
transform-origin:bottom center;
transform:translateX(-50%) rotate(35deg);
}

.center{
position:absolute;
width:16px;
height:16px;
border-radius:50%;
background:white;
left:50%;
top:50%;
transform:translate(-50%,-50%);
}

.speed{
position:absolute;
bottom:35px;
width:100%;
text-align:center;
font-size:24px;
color:#42ff42;
font-weight:bold;
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:10px;
}

.info{
text-align:center;
font-size:20px;
color:#42ff42;
margin-top:5px;
}

.btn{
width:100%;
padding:14px;
border:none;
border-radius:12px;
background:#ffd700;
font-size:18px;
font-weight:bold;
margin-top:10px;
cursor:pointer;
}

.footer{
margin-top:15px;
padding:10px;
border:1px solid #555;
border-radius:12px;
text-align:center;
color:#ffd700;
}
</style>
</head>

<body>

<div class="app">

<div class="title">SkyRoute</div>

<div class="card flight">
London ✈ Istanbul
</div>

<div class="gauge">
<div class="needle"></div>
<div class="center"></div>
<div class="speed" id="speed">842 km/h</div>
</div>

<div class="grid">

<div class="card">
Altitude
<div class="info" id="altitude">36,000 ft</div>
</div>

<div class="card">
Heading
<div class="info" id="heading">089°</div>
</div>

</div>

<div class="map">

<div class="city london">London</div>

<div class="city istanbul">Istanbul</div>

<div class="route"></div>

<div class="plane">✈</div>

</div>

<div class="grid">

<div class="card">
Local Time
<div class="info" id="clock"></div>
</div>

<div class="card">
GPS Status
<div class="info" id="gps">Demo</div>
</div>

</div>

<button class="btn" onclick="startGPS()">
START LIVE GPS
</button>

<div class="footer">
Passenger Flight Tracker
</div>

</div>

<script>

function updateClock(){
const now=new Date();

document.getElementById("clock").innerHTML=
now.getHours().toString().padStart(2,"0")
+":"
+
now.getMinutes().toString().padStart(2,"0");
}

setInterval(updateClock,1000);
updateClock();

function startGPS(){

if(!navigator.geolocation){
alert("GPS not supported");
return;
}

navigator.geolocation.watchPosition(

(pos)=>{

const speed=
pos.coords.speed
?
Math.round(pos.coords.speed*3.6)
:
0;

const alt=
pos.coords.altitude
?
Math.round(pos.coords.altitude*3.28)
:
0;

const head=
pos.coords.heading
?
Math.round(pos.coords.heading)
:
0;

document.getElementById("speed").innerHTML=
speed+" km/h";

document.getElementById("altitude").innerHTML=
alt+" ft";

document.getElementById("heading").innerHTML=
head+"°";

document.getElementById("gps").innerHTML=
"LIVE";

},

(err)=>{
alert("Please allow GPS access");
}

);

}

</script>

</body>
</html>
